# 本地开发环境（docker compose）
# 生产部署见 PRODUCTION.md — 勿将本文件密钥用于生产

# 镜像（本地 build 默认 giso/*:local；对齐 GHCR 时可设）
# 镜像仓库（与 deployment 仓 apps/bigdata/giso/kustomization.yaml 一致）
GISO_IMAGE_REGISTRY=ghcr.io/cloud-gido/giso
# GISO_IMAGE_TAG=latest

# 飞书/Lark 机器人 Webhook（Alertmanager 告警推送）
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/your-hook-id

# 可选：构建基础镜像（国内网络）
# MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-21
# JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine
