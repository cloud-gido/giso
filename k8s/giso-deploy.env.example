# GISO 镜像构建与部署策略（复制为 k8s/giso-deploy.env）
#
# 镜像仓库（GHCR，与 GitHub Actions / deployment 仓库一致）
#   ghcr.io/cloud-gido/giso/giso-gateway:latest
GISO_IMAGE_REGISTRY=ghcr.io/cloud-gido/giso
GISO_IMAGE_TAG=latest

# 构建平台：linux/amd64 | linux/arm64（Kind/Mac 可设 arm64）
# GISO_BUILD_PLATFORM=linux/amd64

# 基础镜像覆盖（国内网络可设 DaoCloud 镜像，参考 gido）
# MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-21
# JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine

# 本地构建后 push 到 registry
# GISO_PUSH=1

# 是否构建资讯 Demo 镜像
# GISO_BUILD_NEWS_DEMO=1

# K8s apply 时替换 giso.yaml 占位符
GISO_GATEWAY_IMAGE=__GATEWAY_IMAGE__
GISO_LARK_WEBHOOK_IMAGE=__LARK_WEBHOOK_IMAGE__

# 外部 Kafka（生产 Doris Routine Load 消费同集群）
GISO_KAFKA_BOOTSTRAP=kafka-broker1:9092,kafka-broker2:9092

# Gateway Secret（apply 脚本写入 K8s Secret，勿提交真实值）
# GISO_APP_KEYS=prod-key-android,prod-key-web
# GISO_ADMIN_USER=admin
# GISO_ADMIN_PASSWORD=change-me
# GISO_VIEWER_USER=viewer
# GISO_VIEWER_PASSWORD=change-me
