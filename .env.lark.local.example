# 复制为 .env.lark.local（已 gitignore，勿提交）
#
# 测试 webhook — push-all.sh / CI 默认使用
LARK_WEBHOOK_URL_TEST=https://open.larksuite.com/open-apis/bot/v2/hook/your-test-hook-id
